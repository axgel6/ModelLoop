# ============================================================================
# ModelLoop Frontend Configuration
# Copy this file to .env and fill in your values
# ============================================================================

# Backend API URL
# The base URL where the FastAPI backend is running
VITE_API_URL=http://localhost:8000

# Optional API Key for Guest Requests
# If set, this key will be sent with guest chat requests via X-API-Key header
VITE_API_KEY=

# Maintenance Mode
# Set to "true" to show the maintenance/down page to all visitors
VITE_IS_DOWN=false
