# ============================================================================
# ModelLoop Backend Configuration
# Copy this file to .env and fill in your values
# ============================================================================

# JWT Configuration
# Generate a secure secret: openssl rand -hex 32
JWT_SECRET=your_secret_key_here_must_be_at_least_32_chars

# Database Configuration
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://modelloop_user:secure_password@localhost:5432/modelloop

# Ollama Configuration
# The base URL where Ollama is running (local or remote)
OLLAMA_URL=http://localhost:11434

# CORS Configuration
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Model Configuration (optional, defaults provided)
DEFAULT_MODEL=llama3.2:latest
VISION_MODEL=gemma3:4b-it-qat
EMBED_MODEL=nomic-embed-text

# Comma-separated substrings of model names that support reasoning
# Models containing these strings will have extended thinking enabled
THINKING_MODELS=deepseek-r1

# JWT Token Expiration (optional)
JWT_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# API Key for Guest Chat Endpoint (optional)
# If set, enables POST /api/v1/guest/chat for unauthenticated users
API_KEY=

# Environment Mode
# Set to "production" for strict security checks and no debug endpoints
APP_ENV=development
